{% doc %}
  Renders a customizable image banner card.

  @param {object} [image] - Image object. Optional.
  @param {object} [mobile_image] - Mobile image object. Optional.
  @param {string} [description] - The description. Optional.
  @param {string} [link] - The link. Optional.
  @param {boolean} [new_window] - Whether to open the link in a new window. Optional.
  @param {string} [class] - Extra CSS classes. Optional.
  @param {number} [columns] - The number of columns the card is rendered in. Optional.
  @param {string} [id] - HTML id. Optional.
  @param {string} [loading] - Loading strategy ('lazy' or 'eager'). Default: lazy.
  @param {string} [fetchpriority] - Priority for image fetching. Default: auto.

  @example
  {% render 'card-image-banner', description: description, image: image %}
{% enddoc %}

{% liquid
  if loading == blank
    assign loading = 'lazy'
  endif

  if fetchpriority == blank
    assign fetchpriority = 'auto'
  endif
%}
<div
  {% if id != blank %}
    id="{{ id }}"
  {% endif %}
  class="card-image-banner {{ class }}"
>
  {% if link %}
    <a
      href="{{ link }}"
      {% if new_window %}
        target="_blank"
      {% endif %}
    >
  {% endif %}

  {% if image != blank %}
    {%- capture image_sizes -%}
      {% if columns == 1 %}
        (min-width: 1420px) 1420px, calc(100vw - 3rem)
      {% else %}
        (min-width: 1200px) calc((100vw - 6rem) / 2), (min-width: 990px) calc((100vw - 6rem) * 0.6), (min-width: 750px) calc(100vw - 4rem), calc(100vw - 3rem)
      {% endif %}
    {%- endcapture -%}

    <picture>
      {% if mobile_image %}
        <source
          srcset="
            {% if mobile_image.width >= 165 %}{{ mobile_image | image_url: width: 165 }} 165w,{% endif %}
            {% if mobile_image.width >= 440 %}{{ mobile_image | image_url: width: 440 }} 440w,{% endif %}
            {% if mobile_image.width >= 650 %}{{ mobile_image | image_url: width: 650 }} 650w,{% endif %}
            {% if mobile_image.width >= 850 %}{{ mobile_image | image_url: width: 850 }} 850w,{% endif %}
            {% if mobile_image.width >= 1100 %}{{ mobile_image | image_url: width: 1100 }} 1100w,{% endif %}
            {% if mobile_image.width >= 1200 %}{{ mobile_image | image_url: width: 1200 }} 1200w,{% endif %}
            {% if mobile_image.width >= 1420 %}{{ mobile_image | image_url: width: 1420 }} 1420w,{% endif %}
            {{ mobile_image | image_url }} {{ mobile_image.width }}w
          "
          sizes="{{ image_sizes }}"
          media="(max-width: 749px)"
        >
      {% endif %}

      {{
        image
        | image_url: width: 1420
        | image_tag:
          sizes: image_sizes,
          widths: '165, 440, 650, 850, 1100, 1200, 1420',
          fetchpriority: fetchpriority,
          loading: loading
      }}
    </picture>

  {% else %}
    {{ 'collection-1' | strip | placeholder_svg_tag: 'placeholder-svg' }}
  {% endif %}

  {% unless description == blank %}
    <span class="visually-hidden">{{ description }}</span>
  {% endunless %}

  {% if link %}
    </a>
  {% endif %}
</div>
