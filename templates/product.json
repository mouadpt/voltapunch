            "text_position": "after",
            "show_bottom_divider": false,
            "values_alignment": "right"
          }
        },
        "expandable-1": {
          "type": "expandable",
          "settings": {
            "title": "Informação de envio",
            "icon": "globe",
            "text": "<p><strong>Encomende até às 14h00 para receber no dia útil seguinte!</strong> Na maioria dos casos, trabalhamos com transportadoras com serviço de 24 horas para que receba a sua encomenda a tempo.</p><p>Existe uma taxa de €4,99 para entregas em encomendas abaixo de €50. Poderão ser aplicadas taxas adicionais pelas nossas transportadoras para entregas em zonas remotas, podendo ser cobrada uma sobretaxa para cobrir o transporte até essas áreas.</p>",
            "page": "",
            "expanded": false,
            "custom_icon": ""
          }
        },
        "expandable-2": {
          "type": "expandable",
          "settings": {
            "title": "Garantia",
            "icon": "shield",
            "text": "<p>O seu produto está coberto por uma garantia de 12 meses, ou mais se optou pela garantia alargada. Certifique-se de que regista o seu produto.</p>",
            "page": "",
            "expanded": false,
            "custom_icon": ""
          }
        },
        "reviews": {
          "type": "reviews",
          "settings": {
            "expanded": false,
            "show_count": false
          }
        }
