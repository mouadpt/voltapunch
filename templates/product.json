            "show_facebook": true,
            "show_twitter": true,
            "show_linkedin": true,
            "show_bottom_divider": false
          }
        },
        "contact_details": {
          "type": "contact_details",
          "settings": {
            "heading": "Fale com um especialista!",
            "image": "",
            "video_chat_link": "#",
            "chat_link": "#",
            "email": "example@example.com",
            "phone_number": "+55 555-12345",
            "color_scheme": "background-2",
            "show_bottom_divider": false
          }
