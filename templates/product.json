        "collapse_other_expandables": false,
        "thumbnails_position": "left",
        "spacing_mode": "desktop",
        "spacing_top": 60,
        "spacing_bottom": 60,
        "spacing_top_mobile": 48,
        "spacing_bottom_mobile": 48
