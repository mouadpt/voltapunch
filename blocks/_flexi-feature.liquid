<div
  class="flexi-feature-item {% if block.settings.title == blank or block.settings.text == blank %}flexi-feature-item-centered{% endif %}{% unless section.settings.inline %} color-{{ section.settings.content_color_scheme }}{% endunless %}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.icon == 'custom' and block.settings.custom_icon != blank %}
    <span class="flexi-feature-icon">
      <img
        src="{{ block.settings.custom_icon | image_url: width: 40 }}"
        srcset="{{ block.settings.custom_icon | image_url: width: 40 }} 1x, {{ block.settings.custom_icon | image_url: width: 80 }} 2x"
        alt="{{ block.settings.custom_icon.alt | escape }}"
        width="{{ block.settings.custom_icon.width }}"
        height="{{ block.settings.custom_icon.height }}"
        loading="lazy"
      >
    </span>
  {% elsif block.settings.icon != blank %}
    <span class="flexi-feature-icon">
      {% render 'icons', icon: block.settings.icon %}
    </span>
  {% endif %}

  <div class="flexi-feature-content">
    {% if block.settings.title != blank %}
      <div class="flexi-feature-title h5">{{ block.settings.title }}</div>
    {% endif %}
    {% if block.settings.text != blank %}
      <div class="flexi-feature-text">
        {{ block.settings.text }}
      </div>
    {% endif %}
  </div>
</div>

