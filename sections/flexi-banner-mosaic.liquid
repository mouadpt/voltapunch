{% liquid
  assign is_empty = true
  for block in section.blocks
    if block.settings.image != blank or block.settings.custom_video != blank
      assign is_empty = false
    endif
  endfor

  assign hide_because_empty = false
  if request.design_mode == false and section.settings.hide_if_empty and is_empty
    assign hide_because_empty = true
  endif

  assign color_scheme_string = section.settings.color_scheme | append: ''
  assign section_content_class = 'section-content'
  unless color_scheme_string == 'background-1'
    assign section_content_class = section_content_class | append: ' section-content-padded'
  endunless

  assign has_video_background = false
  for block in section.blocks
    if block.settings.custom_video != blank or block.settings.video_url != blank
      assign has_video_background = true
    endif
  endfor
%}

{%- unless hide_because_empty -%}
  {{ 'component-card-overlay.css' | asset_url | stylesheet_tag }}
  {{ 'component-scroller.css' | asset_url | stylesheet_tag }}
  {{ 'section-flexi-banner-mosaic.css' | asset_url | stylesheet_tag }}

  {% if has_video_background %}
    {{ 'component-video-background.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'video-background.js' | asset_url }}" defer="defer"></script>
  {% endif %}

  <style>
    #shopify-section-{{ section.id }} .section-content {
      margin-top: {{ section.settings.spacing_top_mobile }}px;
      margin-bottom: {{ section.settings.spacing_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .section-content-padded {
      margin-top: 0;
      margin-bottom: 0;
      padding-top: {{ section.settings.spacing_top_mobile }}px;
      padding-bottom: {{ section.settings.spacing_bottom_mobile }}px;
    }

    @media (min-width: 990px) {
      #shopify-section-{{ section.id }} .section-content {
        margin-top: {{ section.settings.spacing_top }}px;
        margin-bottom: {{ section.settings.spacing_bottom }}px;
      }

      #shopify-section-{{ section.id }} .section-content-padded {
        margin-top: 0;
        margin-bottom: 0;
        padding-top: {{ section.settings.spacing_top }}px;
        padding-bottom: {{ section.settings.spacing_bottom }}px;
      }
    }

    #shopify-section-{{ section.id }} .flexi-mosaic-grid {
      gap: {{ section.settings.grid_gap }}px;
    }

    @media (min-width: 750px) {
      #shopify-section-{{ section.id }} .flexi-mosaic-grid {
        grid-auto-rows: {{ section.settings.row_height }}px;
      }

      {% for block in section.blocks %}
        #shopify-section-{{ section.id }} .flexi-mosaic-item-{{ block.id }} {
          grid-column: span {{ block.settings.col_span }};
          grid-row: span {{ block.settings.row_span }};
        }
      {% endfor %}
    }

    {% for block in section.blocks %}
      {% if block.settings.overlay_type == 'color' %}
        #Card-{{ section.id }}-{{ forloop.index }}::after {
          background: {{ block.settings.overlay_color }};
        }
      {% else %}
        #Card-{{ section.id }}-{{ forloop.index }}::after {
          background: {{ block.settings.overlay_background }};
        }
      {% endif %}
    {% endfor %}

    {% if section.settings.full_width %}
      #shopify-section-{{ section.id }}.section-flexi-banner-mosaic {
        overflow-x: clip;
      }

      #shopify-section-{{ section.id }} .section-fullwidth {
        padding-inline: 1.5rem;
      }

      @media (min-width: 990px) {
        #shopify-section-{{ section.id }} .section-fullwidth {
          padding-inline: 2rem;
        }
      }
    {% endif %}
  </style>

  {%- capture visibility_classes -%}{%- render 'section-visibility-classes' -%}{%- endcapture -%}
  {%- assign visibility_classes = visibility_classes | strip -%}

  <div class="{{ visibility_classes }}">
    <div class="color-{{ section.settings.color_scheme }}">
      <div class="{% if section.settings.full_width %}section-fullwidth{% else %}container{% endif %}">
        <div class="{{ section_content_class }}">
          {%- unless section.settings.stack_on_mobile or section.blocks.size == 1 -%}
            <div class="scroller">
              <div class="scroller-inner">
          {%- endunless -%}

          <div class="flexi-mosaic-grid{% unless section.settings.stack_on_mobile %} flexi-mosaic-scroll{% endunless %}">
            {% for block in section.blocks %}
              {% liquid
                assign loading = 'lazy'
                assign fetchpriority = 'auto'
                if section.index == 1 and forloop.first
                  assign loading = 'eager'
                  assign fetchpriority = 'high'
                endif
              %}

              {% assign id = 'Card-' | append: section.id | append: '-' | append: forloop.index %}
              <div
                class="flexi-mosaic-item flexi-mosaic-item-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {% render 'card-banner',
                  image: block.settings.image,
                  mobile_image: block.settings.mobile_image,
                  id: id,
                  block: block,
                  settings: block.settings,
                  title: block.settings.title,
                  description: block.settings.description,
                  button_link: block.settings.button_link,
                  button_text: block.settings.button_text,
                  new_window: section.settings.links_new_window,
                  show_title: section.settings.show_title,
                  show_description: section.settings.show_description,
                  show_button: section.settings.show_button,
                  overlay: true,
                  class: 'color-background-1',
                  card_clickable_desktop: section.settings.card_clickable_desktop,
                  loading: loading,
                  fetchpriority: fetchpriority
                %}
              </div>
            {% endfor %}
          </div>

          {%- unless section.settings.stack_on_mobile or section.blocks.size == 1 -%}
            </div>
            </div>
          {%- endunless -%}
        </div>
      </div>
    </div>
  </div>
{%- endunless -%}

