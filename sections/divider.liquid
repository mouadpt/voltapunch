<style>
  #shopify-section-{{ section.id }} .section-content {
    margin: 0;
    padding-top: {{ section.settings.spacing_top_mobile }}px;
    padding-bottom: {{ section.settings.spacing_bottom_mobile }}px;
  }

  @media (min-width: 990px) {
    #shopify-section-{{ section.id }} .section-content {
      padding-top: {{ section.settings.spacing_top }}px;
      padding-bottom: {{ section.settings.spacing_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .section-divider {
    max-width: 100%;
    margin: 0 auto;
    width: {{ section.settings.width }}px;
    height: {{ section.settings.height }}px;
    background: {{ section.settings.color_background }};
  }
</style>

<div class="container">
  <div class="section-content">
    <div class="section-divider"></div>
  </div>
</div>

{% schema %}
  {
    "name": "t:sections.divider.name",
    "tag": "section",
    "class": "section section-divider",
    "disabled_on": {
      "groups": ["header", "footer", "custom.overlays"]
    },
    "settings": [
      {
        "type": "number",
        "id": "height",
        "default": 2,
        "label": "t:sections.divider.settings.height.label"
      },
      {
        "type": "number",
        "id": "width",
        "default": 300,
        "label": "t:sections.divider.settings.width.label"
      },
      {
        "type": "color",
        "id": "color_background",
        "alpha": true,
        "label": "t:sections.divider.settings.color_background.label",
        "default": "#dadada"
      },
      {
        "type": "select",
        "id": "spacing_mode",
        "label": "t:sections.all.section_spacing.spacing_mode.label",
        "default": "desktop",
        "options": [
          {
            "value": "desktop",
            "label": "t:sections.all.section_spacing.spacing_mode.options.desktop"
          },
          {
            "value": "mobile",
            "label": "t:sections.all.section_spacing.spacing_mode.options.mobile"
          }
        ]
      },
      {
        "type": "range",
        "id": "spacing_top",
        "min": 0,
        "max": 200,
        "step": 2,
        "default": 60,
        "label": "t:sections.all.section_spacing.spacing_top.label",
        "visible_if": "{{ section.settings.spacing_mode == 'desktop' }}"
      },
      {
        "type": "range",
        "id": "spacing_bottom",
        "min": 0,
        "max": 200,
        "step": 2,
        "default": 60,
        "label": "t:sections.all.section_spacing.spacing_bottom.label",
        "visible_if": "{{ section.settings.spacing_mode == 'desktop' }}"
      },
      {
        "type": "range",
        "id": "spacing_top_mobile",
        "min": 0,
        "max": 200,
        "step": 2,
        "default": 48,
        "label": "t:sections.all.section_spacing.spacing_top.label",
        "visible_if": "{{ section.settings.spacing_mode == 'mobile' }}"
      },
      {
        "type": "range",
        "id": "spacing_bottom_mobile",
        "min": 0,
        "max": 200,
        "step": 2,
        "default": 48,
        "label": "t:sections.all.section_spacing.spacing_bottom.label",
        "visible_if": "{{ section.settings.spacing_mode == 'mobile' }}"
      }
    ],
    "presets": [
      {
        "name": "t:sections.divider.preset.name",
        "category": "t:sections.all.preset_category.layout"
      }
    ]
  }
{% endschema %}
