{% liquid
  assign is_empty = true
  for block in section.blocks
    if block.settings.image != blank
      assign is_empty = false
    endif
  endfor

  assign hide_because_empty = false
  if request.design_mode == false and section.settings.hide_if_empty and is_empty
    assign hide_because_empty = true
  endif
%}
{%- unless hide_because_empty -%}
  {% liquid
    assign has_any_video = false
    for block in section.blocks
      if block.settings.custom_video != blank
        assign has_any_video = true
        break
      endif
    endfor
  %}

  {% if section.blocks.size > 1 or has_any_video %}
    {{ 'flickity.css' | asset_url | stylesheet_tag }}
  {% endif %}
  {{ 'section-slideshow.css' | asset_url | stylesheet_tag }}

  {% if section.blocks.size > 1 or has_any_video %}
    <script src="{{ 'flickity.pkgd.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'slideshow.js' | asset_url }}" defer="defer"></script>
  {% endif %}

  {% if has_any_video %}
    <script src="{{ 'slideshow-video.js' | asset_url }}" defer="defer"></script>
  {% endif %}

  {% liquid
    assign color_scheme_string = section.settings.color_scheme | append: ''
    assign section_content_class = 'section-content'
    unless color_scheme_string == 'background-1'
      assign section_content_class = section_content_class | append: ' section-content-padded'
    endunless
  %}

  <style>
    #shopify-section-{{ section.id }} .section-content {
      margin-top: {{ section.settings.spacing_top_mobile }}px;
      margin-bottom: {{ section.settings.spacing_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .section-content-padded {
      margin-top: 0;
      margin-bottom: 0;
      padding-top: {{ section.settings.spacing_top_mobile }}px;
      padding-bottom: {{ section.settings.spacing_bottom_mobile }}px;
    }

    @media (min-width: 990px) {
      #shopify-section-{{ section.id }} .section-content {
        margin-top: {{ section.settings.spacing_top }}px;
        margin-bottom: {{ section.settings.spacing_bottom }}px;
      }

      #shopify-section-{{ section.id }} .section-content-padded {
        margin-top: 0;
        margin-bottom: 0;
        padding-top: {{ section.settings.spacing_top }}px;
        padding-bottom: {{ section.settings.spacing_bottom }}px;
      }
    }

    {% if section.settings.slide_height == 'adapt_image' and section.blocks.first.settings.image != blank %}
      @media screen and (min-width: 750px) {
        #Slideshow-{{ section.id }} .slideshow-slide::before {
          padding-bottom: {{ 1 | divided_by: section.blocks.first.settings.image.aspect_ratio | times: 100 }}%;
        }
      }
    {% endif %}
  </style>

  {%- capture visibility_classes -%}{%- render 'section-visibility-classes' -%}{%- endcapture -%}
  {%- assign visibility_classes = visibility_classes | strip -%}

  <div class="{{ visibility_classes }}">
    <div class="color-{{ section.settings.color_scheme }}">
      <div class="{% if section.settings.full_width %} section-fullwidth{% else %} container{% endif %}">
        <div class="{{ section_content_class }}">
          {% if section.blocks.size > 1 or has_any_video %}
            <slideshow-component
              id="SlideshowComponent-{{ section.id }}"
              role="region"
              aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
              aria-label="{{ section.settings.accessibility_info | escape }}"
              data-autoplay="{{ section.settings.auto_rotate }}"
              data-speed="{{ section.settings.change_slides_speed }}"
              data-animation-type="{{ section.settings.animation_type }}"
            >
              <div class="slideshow-scroll-container">
          {% endif %}
          <div
            class="slideshow slideshow-size-{{ section.settings.slide_height }}"
            id="Slideshow-{{ section.id }}"
          >
            {%- for block in section.blocks -%}
              {% liquid
                assign has_video = false
                if block.settings.custom_video != blank
                  assign has_video = true
                endif

                assign slide_image = block.settings.image
                if block.settings.custom_video.preview_image != blank and slide_image == blank
                  assign slide_image = block.settings.custom_video.preview_image
                endif
              %}
              <style>
                #Slide-{{ section.id }}-{{ forloop.index }}::after {
                  {% if block.settings.overlay_type == 'color' %}
                    background: {{ block.settings.overlay_color }};
                  {% elsif block.settings.overlay_background != blank %}
                    background: {{ block.settings.overlay_background }};
                  {% endif %}
                }

                @media (min-width: 990px) {
                  #Slide-{{ section.id }}-{{ forloop.index }} .slideshow-content {
                    width: {{ block.settings.content_width }}%;
                  }
                }

                {% if block.settings.mobile_image != blank %}
                  #Slide-{{ section.id }}-{{ forloop.index }} .slideshow-media img {
                    object-position: {{ block.settings.mobile_image.presentation.focal_point }};
                  }
                {% endif %}

                {% if block.settings.image != blank %}
                  @media (min-width: 750px) {
                    #Slide-{{ section.id }}-{{ forloop.index }} .slideshow-media img {
                      object-position: {{ block.settings.image.presentation.focal_point }};
                    }
                  }
                {% endif %}
              </style>
              <div
                class="slideshow-slide"
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                role="group"
                aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
                aria-label="{{ 'sections.slideshow.slide_number' | t: index: forloop.index, total: forloop.length }}"
                tabindex="-1"
                {{ block.shopify_attributes }}
              >
                <div
                  class="slideshow-media {% if slide_image == blank and has_video == false %} slideshow-media-placeholder{% endif %}{% if block.settings.mobile_image != blank %} slideshow-media-with-mobile{% endif %}"
                  {% if has_video %}
                    data-slide-has-video="true"
                  {% endif %}
                >
                  {%- if block.settings.link and block.settings.button_label == blank -%}
                    <a href="{{ block.settings.link }}">
                  {%- endif -%}

                  {%- if slide_image -%}
                    {% capture image_sizes %}
                      {% if section.settings.full_width == true %}
                        100vw
                      {% else %}
                        (min-width: 1420px) 1420px, calc(100vw - 3rem)
                      {% endif %}
                    {% endcapture %}

                    {% liquid
                      assign loading = 'lazy'
                      assign fetchpriority = 'auto'
                      if section.index == 1 and forloop.first
                        assign loading = 'eager'
                        assign fetchpriority = 'high'
                      endif
                    %}

                    <picture>
                      {% if block.settings.mobile_image %}
                        <source
                          srcset="
                            {% if block.settings.mobile_image.width >= 375 %}{{ block.settings.mobile_image | image_url: width: 375 }} 375w,{% endif %}
                            {% if block.settings.mobile_image.width >= 550 %}{{ block.settings.mobile_image | image_url: width: 550 }} 550w,{% endif %}
                            {% if block.settings.mobile_image.width >= 750 %}{{ block.settings.mobile_image | image_url: width: 750 }} 750w,{% endif %}
                            {% if block.settings.mobile_image.width >= 1100 %}{{ block.settings.mobile_image | image_url: width: 1100 }} 1100w,{% endif %}
                            {% if block.settings.mobile_image.width >= 1420 %}{{ block.settings.mobile_image | image_url: width: 1420 }} 1420w,{% endif %}
                            {% if block.settings.mobile_image.width >= 2000 %}{{ block.settings.mobile_image | image_url: width: 2000 }} 2000w,{% endif %}
                            {% if block.settings.mobile_image.width >= 2480 %}{{ block.settings.mobile_image | image_url: width: 2480 }} 2480w,{% endif %}
                            {% if block.settings.mobile_image.width >= 3000 %}{{ block.settings.mobile_image | image_url: width: 3000 }} 3000w,{% endif %}
                            {% if block.settings.mobile_image.width >= 3840 %}{{ block.settings.mobile_image | image_url: width: 3840 }} 3840w,{% endif %}
                            {{ block.settings.mobile_image | image_url }} {{ block.settings.mobile_image.width }}w
                          "
                          sizes="{{ image_sizes }}"
                          media="(max-width: 749px)"
                        >
                      {% endif %}

                      {{
                        slide_image
                        | image_url: width: 3840
                        | image_tag:
                          class: 'slideshow-backdrop-image',
                          fetchpriority: fetchpriority,
                          loading: loading,
                          sizes: image_sizes,
                          widths: '375, 550, 750, 1100, 1420, 2000, 2480, 3000, 3840'
                      }}
                    </picture>
                  {%- elsif has_video == false -%}
                    {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}

                  {% if has_video %}
                    <slideshow-video
                      class="slideshow-video {% unless block.settings.enable_video_mobile %}slideshow-video-mobile-disabled{% endunless %}"
                      data-slide-index="{{ forloop.index0 }}"
                    >
                      <video muted playsinline preload="none" loop>
                        {% for source in block.settings.custom_video.sources %}
                          <source data-src="{{ source.url }}" type="{{ source.mime_type }}">
                        {% endfor %}
                      </video>
                    </slideshow-video>
                  {% endif %}

                  {%- if block.settings.link and block.settings.button_label == blank -%}
                    </a>
                  {%- endif -%}
                </div>

                {%- if block.settings.heading != blank
                  or block.settings.subheading != blank
                  or block.settings.button_label != blank
                -%}
                  <div class="slideshow-content-wrap">
                    {%- if section.settings.full_width -%}
                      <div class="container">
                    {%- endif -%}

                    <div class="slideshow-content-container slideshow-content-container-{{ section.settings.slide_height }}{% if section.settings.navigation_position == 'inside' %} slideshow-content-container-inside{% endif %} content-align-{{ block.settings.mobile_box_align }} content-align-desktop-{{ block.settings.box_align }}">
                      <div class="slideshow-content" style="color: {{ block.settings.text_color }}">
                        {%- if block.settings.heading != blank -%}
                          <{{ section.settings.heading_tag }} class="slideshow-heading h2 slideshow-heading-{{ block.settings.mobile_heading_size }} slideshow-heading-desktop-{{ block.settings.heading_size }}">
                            {{ block.settings.heading }}
                          </{{ section.settings.heading_tag }}>
                        {%- endif -%}
                        {%- if block.settings.subheading != blank -%}
                          <div
                            class="slideshow-text rte text-size-{{ block.settings.subheading_size }}"
                            {{ block.shopify_attributes }}
                          >
                            {{ block.settings.subheading }}
                          </div>
                        {%- endif -%}
                        {%- if block.settings.button_label != blank
                          or block.settings.secondary_button_label != blank
                        -%}
                          <div class="slideshow-buttons">
                            {% if block.settings.button_label != blank %}
                              <a
                                {% if block.settings.link %}
                                  href="{{ block.settings.link }}"
                                {% else %}
                                  role="link" aria-disabled="true"
                                {% endif %}
                                class="{% if block.settings.button_type_link %}button-text-link{% else %}button color-button-{{ block.settings.button_color_scheme }}{% endif %}"
                              >
                                {{ block.settings.button_label | escape }}
                              </a>
                            {% endif %}

                            {% if block.settings.secondary_button_label != blank %}
                              <a
                                {% if block.settings.secondary_link %}
                                  href="{{ block.settings.secondary_link }}"
                                {% else %}
                                  role="link" aria-disabled="true"
                                {% endif %}
                                class="{% if block.settings.secondary_button_type_link %}button-text-link{% else %}button color-button-{{ block.settings.secondary_button_color_scheme }}{% endif %}"
                              >
                                {{ block.settings.secondary_button_label | escape }}
                              </a>
                            {% endif %}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>

                    {%- if section.settings.full_width -%}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}

                {% if block.settings.badge_overlay_line_1_text != blank
                  or block.settings.badge_overlay_line_2_text != blank
                  or block.settings.badge_overlay_line_3_text != blank
                %}
                  <div
                    class="slideshow-badge-overlay card-badge-overlay card-badge-overlay-position-{{ block.settings.badge_overlay_position }}"
                    style="color: {{ block.settings.badge_overlay_colors_text }}; background-color: {{ block.settings.badge_overlay_colors_background }};"
                  >
                    {% if block.settings.badge_overlay_line_1_text != blank %}
                      <span class="card-badge-overlay-text card-badge-overlay-text-1 card-badge-overlay-text-{{ block.settings.badge_overlay_line_1_font_size }}">
                        {{ block.settings.badge_overlay_line_1_text }}
                      </span>
                    {% endif %}
                    {% if block.settings.badge_overlay_line_2_text != blank %}
                      <span class="card-badge-overlay-text card-badge-overlay-text-2 card-badge-overlay-text-{{ block.settings.badge_overlay_line_2_font_size }}">
                        {{ block.settings.badge_overlay_line_2_text }}
                      </span>
                    {% endif %}
                    {% if block.settings.badge_overlay_line_3_text != blank %}
                      <span class="card-badge-overlay-text card-badge-overlay-text-3 card-badge-overlay-text-{{ block.settings.badge_overlay_line_3_font_size }}">
                        {{ block.settings.badge_overlay_line_3_text }}
                      </span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {%- endfor -%}
          </div>

          {%- if section.blocks.size > 1 or has_any_video -%}
            </div>
          {%- endif -%}

          {%- if section.blocks.size > 1 -%}
            <slideshow-navigation for="Slideshow-{{ section.id }}">
              <div class="slideshow-controls {% if section.settings.navigation_position == 'inside' %}slideshow-controls-inside{% endif %}">
                <button
                  type="button"
                  class="slideshow-button slideshow-button-prev js-prev"
                  name="previous"
                  aria-label="{{ 'sections.slideshow.previous_slide' | t }}"
                  aria-controls="Slideshow-{{ section.id }}"
                >
                  {% render 'icons', icon: 'arrow-left-thick' %}
                </button>
                <div class="slideshow-pagination">
                  {%- for block in section.blocks -%}
                    <button
                      class="slideshow-pagination-link js-page {% if forloop.index0 == 0 %} is-active{% endif %}"
                      aria-label="{{ 'sections.slideshow.load_slide_number' | t: index: forloop.index, total: forloop.length }}"
                      aria-controls="Slideshow-{{ section.id }}"
                      {{ block.shopify_attributes }}
                    >
                      <span class="slideshow-dot"></span>
                    </button>
                  {%- endfor -%}
                </div>
                <button
                  type="button"
                  class="slideshow-button slideshow-button-next js-next"
                  name="next"
                  aria-label="{{ 'sections.slideshow.next_slide' | t }}"
                  aria-controls="Slideshow-{{ section.id }}"
                >
                  {% render 'icons', icon: 'arrow-right-thick' %}
                </button>
              </div>
            </slideshow-navigation>
          {%- endif -%}

          {%- if section.blocks.size > 1 or has_any_video -%}
            </slideshow-component>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
{%- endunless -%}
{% schema %}
  {
    "name": "t:sections.slideshow.name",
    "tag": "section",
    "class": "section section-slideshow",
    "disabled_on": {
      "groups": ["header", "footer", "custom.overlays"]
    },
    "settings": [
      {
        "type": "header",
        "content": "t:sections.slideshow.settings.header_settings.content"
      },
      {
        "type": "checkbox",
        "id": "auto_rotate",
        "label": "t:sections.slideshow.settings.auto_rotate.label",
        "default": false
      },
      {
        "type": "select",
        "id": "animation_type",
        "label": "t:sections.slideshow.settings.animation_type.label",
        "default": "slide",
        "options": [
          {
            "value": "slide",
            "label": "t:sections.slideshow.settings.animation_type.options.label_1"
          },
          {
            "value": "fade",
            "label": "t:sections.slideshow.settings.animation_type.options.label_2"
          }
        ]
      },
      {
        "type": "select",
        "id": "navigation_position",
        "label": "t:sections.slideshow.settings.navigation_position.label",
        "default": "bottom",
        "options": [
          {
            "value": "inside",
            "label": "t:sections.slideshow.settings.navigation_position.options.label_inside"
          },
          {
            "value": "bottom",
            "label": "t:sections.slideshow.settings.navigation_position.options.label_bottom"
          }
        ]
      },
      {
        "type": "range",
        "id": "change_slides_speed",
        "min": 3,
        "max": 9,
        "step": 1,
        "unit": "s",
        "label": "t:sections.slideshow.settings.change_slides_speed.label",
        "default": 5,
        "visible_if": "{{ section.settings.auto_rotate }}"
      },
      {
        "type": "header",
        "content": "t:sections.all.layout.heading"
      },
      {
        "type": "checkbox",
        "id": "full_width",
        "label": "t:sections.slideshow.settings.full_width.label",
        "default": false
      },
      {
        "type": "select",
        "id": "slide_height",
        "label": "t:sections.slideshow.settings.slide_height.label",
        "default": "adapt_image",
        "options": [
          {
            "value": "adapt_image",
            "label": "t:sections.slideshow.settings.slide_height.options.label_1"
          },
          {
            "value": "small",
            "label": "t:sections.slideshow.settings.slide_height.options.label_2"
          },
          {
            "value": "medium",
            "label": "t:sections.slideshow.settings.slide_height.options.label_3"
          },
          {
            "value": "large",
            "label": "t:sections.slideshow.settings.slide_height.options.label_4"
          },
          {
            "value": "full",
            "label": "t:sections.slideshow.settings.slide_height.options.label_5"
          },
          {
            "value": "three-quarters",
            "label": "t:sections.slideshow.settings.slide_height.options.label_6"
          },
          {
            "value": "two-thirds",
            "label": "t:sections.slideshow.settings.slide_height.options.label_7"
          }
        ]
      },

      {
        "type": "text",
        "id": "accessibility_info",
        "label": "t:sections.slideshow.settings.accessibility_info.label",
        "info": "t:sections.slideshow.settings.accessibility_info.info"
      },
      {
        "type": "header",
        "content": "t:sections.all.colors.heading"
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:sections.all.colors.color_scheme.label",
        "default": "background-1"
      },
      {
        "type": "header",
        "content": "t:sections.all.section_spacing.heading"
      },
      {
        "type": "select",
        "id": "spacing_mode",
        "label": "t:sections.all.section_spacing.spacing_mode.label",
        "default": "desktop",
        "options": [
          {
            "value": "desktop",
            "label": "t:sections.all.section_spacing.spacing_mode.options.desktop"
          },
          {
            "value": "mobile",
            "label": "t:sections.all.section_spacing.spacing_mode.options.mobile"
          }
        ]
      },
      {
        "type": "range",
        "id": "spacing_top",
        "min": 0,
        "max": 150,
        "step": 2,
        "default": 60,
        "label": "t:sections.all.section_spacing.spacing_top.label",
        "visible_if": "{{ section.settings.spacing_mode == 'desktop' }}"
      },
      {
        "type": "range",
        "id": "spacing_bottom",
        "min": 0,
        "max": 150,
        "step": 2,
        "default": 60,
        "label": "t:sections.all.section_spacing.spacing_bottom.label",
        "visible_if": "{{ section.settings.spacing_mode == 'desktop' }}"
      },
      {
        "type": "range",
        "id": "spacing_top_mobile",
        "min": 0,
        "max": 150,
        "step": 2,
        "default": 48,
        "label": "t:sections.all.section_spacing.spacing_top.label",
        "visible_if": "{{ section.settings.spacing_mode == 'mobile' }}"
      },
      {
        "type": "range",
        "id": "spacing_bottom_mobile",
        "min": 0,
        "max": 150,
        "step": 2,
        "default": 48,
        "label": "t:sections.all.section_spacing.spacing_bottom.label",
        "visible_if": "{{ section.settings.spacing_mode == 'mobile' }}"
      },
      {
        "type": "header",
        "content": "t:sections.all.advanced.seo_heading.label"
      },
      {
        "type": "select",
        "id": "heading_tag",
        "label": "t:sections.all.advanced.heading_tag.label",
        "default": "h2",
        "options": [
          {
            "value": "h1",
            "label": "H1"
          },
          {
            "value": "h2",
            "label": "H2"
          },
          {
            "value": "h3",
            "label": "H3"
          }
        ]
      },
      {
        "type": "header",
        "content": "t:sections.all.advanced.visibility_heading.label"
      },
      {
        "type": "checkbox",
        "id": "show_on_desktop",
        "default": true,
        "label": "t:sections.all.advanced.show_on_desktop.label"
      },
      {
        "type": "checkbox",
        "id": "show_on_mobile",
        "default": true,
        "label": "t:sections.all.advanced.show_on_mobile.label"
      },
      {
        "type": "checkbox",
        "id": "hide_if_empty",
        "default": false,
        "label": "t:sections.slideshow.settings.hide_if_empty.label",
        "info": "t:sections.all.advanced.hide_if_empty.info"
      }
    ],
    "blocks": [
      {
        "type": "slide",
        "name": "t:sections.slideshow.blocks.slide.name",
        "limit": 5,
        "settings": [
          {
            "type": "header",
            "content": "t:sections.all.section_background_media.heading"
          },
          {
            "type": "image_picker",
            "id": "image",
            "label": "t:sections.slideshow.blocks.slide.settings.image.label",
            "info": "t:sections.slideshow.blocks.slide.settings.image.info"
          },
          {
            "type": "video",
            "id": "custom_video",
            "label": "t:sections.slideshow.blocks.slide.settings.custom_video.label"
          },
          {
            "type": "select",
            "id": "overlay_type",
            "label": "t:sections.all.overlay.overlay_type.label",
            "default": "gradient",
            "options": [
              {
                "value": "gradient",
                "label": "t:sections.all.overlay.overlay_type.options.gradient"
              },
              {
                "value": "color",
                "label": "t:sections.all.overlay.overlay_type.options.color"
              }
            ]
          },
          {
            "type": "color_background",
            "id": "overlay_background",
            "label": "t:sections.all.gradient.overlay_background.label",
            "default": "linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.8) 100%)",
            "visible_if": "{{ block.settings.overlay_type == 'gradient' }}"
          },
          {
            "type": "color",
            "id": "overlay_color",
            "alpha": true,
            "label": "t:sections.all.overlay.overlay_color.label",
            "default": "#0000007F",
            "visible_if": "{{ block.settings.overlay_type == 'color' }}"
          },
          {
            "type": "header",
            "content": "t:sections.all.section_content.heading"
          },
          {
            "type": "inline_richtext",
            "id": "heading",
            "default": "Image slide",
            "label": "t:sections.slideshow.blocks.slide.settings.heading.label"
          },
          {
            "type": "select",
            "id": "heading_size",
            "label": "t:sections.slideshow.blocks.slide.settings.heading_size.label",
            "default": "md",
            "options": [
              {
                "value": "sm",
                "label": "t:sections.slideshow.blocks.slide.settings.heading_size.options.label_sm"
              },
              {
                "value": "md",
                "label": "t:sections.slideshow.blocks.slide.settings.heading_size.options.label_md"
              },
              {
                "value": "lg",
