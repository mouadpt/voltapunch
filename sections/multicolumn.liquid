{% liquid
  assign is_empty = true
  for block in section.blocks
    if block.settings.image != blank or block.settings.title != blank or block.settings.text != blank
      assign is_empty = false
    endif
  endfor

  assign hide_because_empty = false
  if request.design_mode == false and section.settings.hide_if_empty and is_empty
    assign hide_because_empty = true
  endif
%}
{%- unless hide_because_empty -%}
  {{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}

  {% liquid
    assign color_scheme_string = section.settings.color_scheme | append: ''
    assign section_content_class = 'section-content'
    unless color_scheme_string == 'background-1'
      assign section_content_class = section_content_class | append: ' section-content-padded'
    endunless
  %}

  <style>
    #shopify-section-{{ section.id }} .section-content {
      margin-top: {{ section.settings.spacing_top_mobile }}px;
      margin-bottom: {{ section.settings.spacing_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .section-content-padded {
      margin-top: 0;
      margin-bottom: 0;
      padding-top: {{ section.settings.spacing_top_mobile }}px;
      padding-bottom: {{ section.settings.spacing_bottom_mobile }}px;
    }

    @media (min-width: 990px) {
      #shopify-section-{{ section.id }} .section-content {
        margin-top: {{ section.settings.spacing_top }}px;
        margin-bottom: {{ section.settings.spacing_bottom }}px;
      }

      #shopify-section-{{ section.id }} .section-content-padded {
        margin-top: 0;
        margin-bottom: 0;
        padding-top: {{ section.settings.spacing_top }}px;
        padding-bottom: {{ section.settings.spacing_bottom }}px;
      }
    }
  </style>

  {%- capture visibility_classes -%}{%- render 'section-visibility-classes' -%}{%- endcapture -%}
  {%- assign visibility_classes = visibility_classes | strip -%}

  <div class="{{ visibility_classes }}">
    <div class="color-{{ section.settings.color_scheme }}">
      <div class="container">
        <div class="{{ section_content_class }}">
          <div class="multicolumn">
            {% if section.settings.title != blank
              or section.settings.subtitle != blank
              or section.settings.button_label != blank
              and section.settings.headings_alignment == 'left'
            %}
              <div class="section-headings {% if section.settings.subtitle != blank %}with-subheading{% endif %}">
                {% if section.settings.title != blank or section.settings.subtitle != blank %}
                  <div class="section-headings-content{% if section.settings.headings_alignment == 'center' %} center-aligned{% endif %}">
                    {% if section.settings.title != blank %}
                      <{{ section.settings.heading_tag }} class="section-heading heading-size-{{ section.settings.heading_size }}">
                        {{- section.settings.title -}}
                      </{{ section.settings.heading_tag }}>
                    {% endif %}
                    {% if section.settings.subtitle != blank %}
                      <p class="section-subheading">{{ section.settings.subtitle }}</p>
                    {% endif %}
                  </div>
                {% endif %}

                {% if section.settings.button_label != blank
                  and section.settings.button_link != blank
                  and section.settings.headings_alignment == 'left'
                %}
                  <div class="section-headings-actions">
                    <a
                      class="button button-tertiary"
                      {% if section.settings.button_link == blank %}
                        role="link" aria-disabled="true"
                      {% else %}
                        href="{{ section.settings.button_link }}"
                      {% endif %}
                    >
                      {{ section.settings.button_label | escape }}
                      {% render 'angle', direction: 'right' %}
                    </a>
                  </div>
                {% endif %}
              </div>
            {% endif %}

            <ul
              class="multicolumn-list grid grid-1-col grid-2-col-tablet grid-{{ section.settings.columns }}-col-desktop"
              role="list"
            >
              {%- for block in section.blocks -%}
                <li
                  id="Slide-{{ section.id }}-{{ forloop.index }}"
                  class="grid-item"
                  {{ block.shopify_attributes }}
                >
                  <div class="multicolumn-card {{ section.settings.column_alignment }}">
                    {%- if block.settings.image != blank -%}
                      {%- assign image_size = block.settings.image_width -%}
                      {%- assign image_size2 = block.settings.image_width | times: 2 -%}
                      <style>
                        #Slide-{{ section.id }}-{{ forloop.index }} img { width: {{ block.settings.image_width }}px; }
                      </style>

                      <div class="multicolumn-card-image-wrapper">
                        <div class="media">
                          {%- capture image_sizes -%}
                            {{ block.settings.image | image_url: width: image_size }} 1x, {{ block.settings.image | image_url: width: image_size2 }} 2x
                          {%- endcapture -%}
                          {{
                            block.settings.image
                            | image_url: width: 1100
                            | image_tag: class: 'multicolumn-card-image', srcset: image_sizes
                          }}
                        </div>
                      </div>
                    {%- endif -%}

                    <div class="multicolumn-card-info">
                      {%- if block.settings.title != blank -%}
                        <h3>{{ block.settings.title | escape }}</h3>
                      {%- endif -%}
                      {%- if block.settings.text != blank -%}
                        <div class="rte">{{ block.settings.text }}</div>
                      {%- endif -%}
                      {%- if block.settings.link_label != blank -%}
                        <a
                          class="button"
                          {% if block.settings.link == blank %}
                            role="link" aria-disabled="true"
                          {% else %}
                            href="{{ block.settings.link }}"
                          {% endif %}
                        >
                          {{ block.settings.link_label | escape }}
                        </a>
                      {%- endif -%}
                    </div>
                  </div>
                </li>
              {%- endfor -%}
            </ul>

            {% if section.settings.button_label != blank
              and section.settings.button_link != blank
              and section.settings.headings_alignment == 'center'
            %}
              <div class="section-footer-content text-center">
                <a
                  class="button button-tertiary"
                  {% if section.settings.button_link == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ section.settings.button_link }}"
                  {% endif %}
                >
                  {{ section.settings.button_label | escape }}
                  {% render 'angle', direction: 'right' %}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
{%- endunless -%}
{% schema %}
  {
    "name": "t:sections.multicolumn.name",
    "tag": "section",
    "class": "section section-multicolumn",
    "disabled_on": {
      "groups": ["header", "footer", "custom.overlays"]
    },
    "settings": [
      {
        "type": "header",
        "content": "t:sections.all.section_content.heading"
      },
      {
        "type": "inline_richtext",
        "id": "title",
        "label": "t:sections.multicolumn.settings.title.label"
      },
      {
        "type": "select",
        "id": "heading_size",
        "label": "t:sections.all.heading_size.label",
        "default": "md",
        "options": [
          {
            "value": "sm",
            "label": "t:sections.all.heading_size.options.label_sm"
          },
          {
            "value": "md",
            "label": "t:sections.all.heading_size.options.label_md"
          },
          {
            "value": "lg",
            "label": "t:sections.all.heading_size.options.label_lg"
          },
          {
            "value": "xl",
            "label": "t:sections.all.heading_size.options.label_xl"
          },
          {
            "value": "xxl",
            "label": "t:sections.all.heading_size.options.label_xxl"
          }
        ]
      },
      {
        "type": "inline_richtext",
        "id": "subtitle",
        "label": "t:sections.multicolumn.settings.subtitle.label"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "t:sections.multicolumn.settings.button_label.label"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "t:sections.multicolumn.settings.button_link.label"
      },
      {
        "type": "select",
        "id": "headings_alignment",
        "label": "t:sections.all.headings_alignment.label_section",
        "default": "left",
        "options": [
          {
            "value": "left",
            "label": "t:sections.all.headings_alignment.options.label_left"
          },
          {
            "value": "center",
            "label": "t:sections.all.headings_alignment.options.label_center"
          }
        ]
      },
      {
        "type": "header",
        "content": "t:sections.all.layout.heading"
      },
      {
        "type": "range",
        "id": "columns",
        "min": 2,
        "max": 6,
        "step": 1,
        "default": 3,
        "label": "t:sections.all.layout.columns.label"
      },

      {
        "type": "select",
        "id": "column_alignment",
        "label": "t:sections.multicolumn.settings.column_alignment.label",
        "default": "left",
        "options": [
          {
            "value": "left",
            "label": "t:sections.multicolumn.settings.column_alignment.options.label_1"
          },
          {
            "value": "center",
            "label": "t:sections.multicolumn.settings.column_alignment.options.label_2"
          },
          {
            "value": "right",
            "label": "t:sections.multicolumn.settings.column_alignment.options.label_3"
          }
        ]
      },
      {
        "type": "header",
        "content": "t:sections.all.colors.heading"
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:sections.all.colors.color_scheme.label",
        "default": "background-1"
      },
      {
        "type": "header",
        "content": "t:sections.all.section_spacing.heading"
      },
      {
        "type": "select",
        "id": "spacing_mode",
        "label": "t:sections.all.section_spacing.spacing_mode.label",
        "default": "desktop",
        "options": [
          {
            "value": "desktop",
            "label": "t:sections.all.section_spacing.spacing_mode.options.desktop"
          },
          {
            "value": "mobile",
            "label": "t:sections.all.section_spacing.spacing_mode.options.mobile"
          }
        ]
      },
      {
        "type": "range",
        "id": "spacing_top",
        "min": 0,
        "max": 150,
        "step": 2,
        "default": 60,
        "label": "t:sections.all.section_spacing.spacing_top.label",
        "visible_if": "{{ section.settings.spacing_mode == 'desktop' }}"
      },
      {
        "type": "range",
        "id": "spacing_bottom",
        "min": 0,
        "max": 150,
        "step": 2,
        "default": 60,
        "label": "t:sections.all.section_spacing.spacing_bottom.label",
        "visible_if": "{{ section.settings.spacing_mode == 'desktop' }}"
      },
      {
        "type": "range",
        "id": "spacing_top_mobile",
        "min": 0,
        "max": 150,
        "step": 2,
        "default": 48,
        "label": "t:sections.all.section_spacing.spacing_top.label",
        "visible_if": "{{ section.settings.spacing_mode == 'mobile' }}"
      },
      {
        "type": "range",
        "id": "spacing_bottom_mobile",
        "min": 0,
        "max": 150,
        "step": 2,
        "default": 48,
        "label": "t:sections.all.section_spacing.spacing_bottom.label",
        "visible_if": "{{ section.settings.spacing_mode == 'mobile' }}"
      },
      {
        "type": "header",
        "content": "t:sections.all.advanced.seo_heading.label"
      },
      {
        "type": "select",
        "id": "heading_tag",
        "label": "t:sections.all.advanced.heading_tag.label",
        "default": "h2",
        "options": [
          {
            "value": "h1",
            "label": "H1"
          },
          {
            "value": "h2",
            "label": "H2"
          },
          {
            "value": "h3",
            "label": "H3"
          }
        ]
      },
      {
        "type": "header",
        "content": "t:sections.all.advanced.visibility_heading.label"
      },
      {
        "type": "checkbox",
        "id": "show_on_desktop",
        "default": true,
        "label": "t:sections.all.advanced.show_on_desktop.label"
      },
      {
        "type": "checkbox",
        "id": "show_on_mobile",
        "default": true,
        "label": "t:sections.all.advanced.show_on_mobile.label"
      },
      {
        "type": "checkbox",
        "id": "hide_if_empty",
        "default": false,
        "label": "t:sections.multicolumn.settings.hide_if_empty.label",
        "info": "t:sections.all.advanced.hide_if_empty.info"
      }
    ],
    "blocks": [
      {
        "type": "column",
        "name": "t:sections.multicolumn.blocks.column.name",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "t:sections.multicolumn.blocks.column.settings.image.label"
          },
          {
            "type": "range",
            "id": "image_width",
            "min": 10,
            "max": 700,
            "step": 10,
            "default": 550,
            "unit": "px",
            "label": "t:sections.multicolumn.blocks.column.settings.image_width.label"
          },
          {
            "type": "text",
            "id": "title",
            "default": "Column",
            "label": "t:sections.multicolumn.blocks.column.settings.title.label"
          },
          {
            "type": "richtext",
            "id": "text",
            "default": "<p>Pair text with an image to focus on your chosen product, collection, or blog post. Add details on availability, style, or even provide a review.</p>",
            "label": "t:sections.multicolumn.blocks.column.settings.text.label"
          },
          {
            "type": "text",
            "id": "link_label",
            "label": "t:sections.all.links.link_title.label"
          },
          {
            "type": "url",
            "id": "link",
            "label": "t:sections.all.links.link_url.label"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "t:sections.multicolumn.presets.name",
        "category": "t:sections.all.preset_category.content",
        "blocks": [
          {
            "type": "column"
          },
          {
            "type": "column"
          },
          {
            "type": "column"
          }
        ]
      }
    ]
  }
{% endschema %}
