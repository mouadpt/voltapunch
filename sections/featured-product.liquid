{% comment %}theme-check-disable TemplateLength{% endcomment %}
{% liquid
  assign hide_because_empty = false
  if request.design_mode == false and section.settings.hide_if_empty and section.settings.product == blank
    assign hide_because_empty = true
  endif
%}
{%- unless hide_because_empty -%}
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-pills.css' | asset_url | stylesheet_tag }}
  {{ 'component-tooltip.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  {% liquid
    assign product = section.settings.product
    assign first_3d_model = product.media | where: 'media_type', 'model' | first
    assign product_form_id = 'product-form-' | append: section.id
    assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'

    assign color_scheme_string = section.settings.color_scheme | append: ''
    assign section_content_class = 'section-content'
    unless color_scheme_string == 'background-1'
      assign section_content_class = section_content_class | append: ' section-content-padded'
    endunless

    # theme-check-disable-next-line VariableName
    assign preorderSuffixArray = product.template_suffix | split: 'pre-order-'
    assign is_pre_order = false
    if product.template_suffix != blank and preorderSuffixArray[0] == blank or product.template_suffix == 'pre-order'
      assign is_pre_order = true
    endif

    assign has_media = false
    if product.media.size > 0 or settings.product_placeholder_image
      assign has_media = true
    endif

    # We set the media to true a product is not selected to maintain the preview.
    if product == blank
      assign has_media = true
    endif

    assign is_variant_selected = false
    assign selected_variant = null
    if section.settings.preselect_variant == true and product.selected_or_first_available_variant != blank
      assign is_variant_selected = true
      assign selected_variant = product.selected_or_first_available_variant
    endif
    if section.settings.preselect_variant == false and product.selected_variant != blank
      assign is_variant_selected = true
      assign selected_variant = product.selected_variant
    endif
    if product.has_only_default_variant or product.variants_count == 1
      assign is_variant_selected = true
      assign selected_variant = product.selected_or_first_available_variant
    endif
  %}
  {% if has_media %}
    {{ 'flickity.css' | asset_url | stylesheet_tag }}
  {% endif %}

  {%- if first_3d_model -%}
    <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

  <style>
    #shopify-section-{{ section.id }} .section-content {
      margin-top: {{ section.settings.spacing_top_mobile }}px;
      margin-bottom: {{ section.settings.spacing_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .section-content-padded {
      margin-top: 0;
      margin-bottom: 0;
      padding-top: {{ section.settings.spacing_top_mobile }}px;
      padding-bottom: {{ section.settings.spacing_bottom_mobile }}px;
    }

    @media (min-width: 990px) {
      #shopify-section-{{ section.id }} .section-content {
        margin-top: {{ section.settings.spacing_top }}px;
        margin-bottom: {{ section.settings.spacing_bottom }}px;
      }

      #shopify-section-{{ section.id }} .section-content-padded {
        margin-top: 0;
        margin-bottom: 0;
        padding-top: {{ section.settings.spacing_top }}px;
        padding-bottom: {{ section.settings.spacing_bottom }}px;
      }
    }
  </style>

  {%- capture visibility_classes -%}{%- render 'section-visibility-classes' -%}{%- endcapture -%}
  {%- assign visibility_classes = visibility_classes | strip -%}

  <div class="{{ visibility_classes }}">
    <div class="color-{{ section.settings.color_scheme }}">
      <div class="container {% if has_media == false %}container-narrow{% endif %}">
        <div class="{{ section_content_class }}">
          {% if section.settings.heading != blank or section.settings.subheading != blank %}
            <div class="section-headings {% if section.settings.subheading != blank %}with-subheading{% endif %}">
              <div class="section-headings-content{% if section.settings.headings_alignment == 'center' %} center-aligned{% endif %}">
                {% if section.settings.heading != blank %}
                  <{{ section.settings.heading_tag }} class="section-heading heading-size-{{ section.settings.heading_size }}">
                    {{ section.settings.heading }}
                  </{{ section.settings.heading_tag }}>
                {% endif %}
                {% if section.settings.subheading != blank %}
                  <p class="section-subheading">{{ section.settings.subheading }}</p>
                {% endif %}
              </div>
            </div>
          {% endif %}

          <div
            id="ProductPage-{{ section.id }}"
            data-section-id="{{ section.id }}"
            class="product product-page product-section-featured {% if has_media == false %}product-no-media{% endif %}"
          >
            {% if has_media or product == blank %}
              <div class="product-media-gallery-wrap">
                {% render 'product-media-gallery',
                  product: product,
                  section: section,
                  variant_images: variant_images
                %}
              </div>
            {% endif %}

            <div class="product-info-wrap-content">
              <div id="Product-{{ section.id }}" class="product-info">
                {% for block in section.blocks %}
                  {% case block.type %}
                    {% when '@app' %}
                      <div class="product-info-secondary" {{ block.shopify_attributes }}>
                        {% render block %}
                      </div>

                    {%- when 'text' -%}
                      {% if block.settings.text != blank
                        or block.settings.text_2 != blank
                        or block.settings.text_3 != blank
                        or block.settings.text_4 != blank
                      %}
                        <div
                          class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                          {{ block.shopify_attributes }}
                        >
                          {% render 'main-product-text-block', block: block %}
                        </div>
                      {% endif %}

                    {%- when 'richtext' -%}
                      {% if block.settings.content != blank %}
                        {% assign color_scheme_string = block.settings.color_scheme | append: '' %}
                        <div
                          class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                          {{ block.shopify_attributes }}
                        >
                          <div class="product-info-secondary product-info-secondary-rich-text rte {% if color_scheme_string != 'background-1' %} card color-{{ block.settings.color_scheme }}{% endif %}">
                            {{ block.settings.content }}
                          </div>
                        </div>
                      {% endif %}

                    {% when 'title' %}
                      <div
                        class="product-info-main product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %} product-block-content-{{ section.id }} variant-changed-update"
                        {{ block.shopify_attributes }}
                      >
                        {% if block.settings.show_custom_badges %}
                          {% render 'card-product-custom-badges',
                            product: product,
                            class: 'product-info-badges'
                          %}
                        {% endif %}

                        {% if block.settings.show_vendor and product.vendor != blank %}
                          {% liquid
                            assign matching_collection = false
                            assign vendor_handle = product.vendor | handleize
                            for collection in product.collections
                              if collection.handle == vendor_handle
                                assign matching_collection = true
                              endif
                            endfor
                          %}
                          <div class="product-info-eyebrow">
                            {% if matching_collection %}
                              <a href="{{ routes.collections_url }}/{{ vendor_handle }}">
                                {{- product.vendor -}}
                              </a>
                            {% else %}
                              {{ product.vendor | link_to_vendor }}
                            {% endif %}
                          </div>
                        {% endif %}

                        <{{ block.settings.block_heading_tag }} class="product-info-heading h2">
                          {% if product.title != blank %}
                            {{ product.title | escape }}
                          {% else %}
                            {{ 'onboarding.product_title' | t }}
                          {% endif %}
                        </{{ block.settings.block_heading_tag }}>

                        {% liquid
                          assign product_info_meta_stretch_class = ''
                          if product.selected_or_first_available_variant.barcode and block.settings.show_barcode and product.selected_or_first_available_variant.sku and block.settings.show_sku
                            assign product_info_meta_stretch_class = 'product-info-meta-stretch'
                          endif
                        %}

                        {% if block.settings.show_stock
                          or block.settings.show_sku
                          or block.settings.show_barcode
                          or block.settings.show_rating
                        %}
                          <div
                            id="ProductInfoMeta-{{ section.id }}"
                            class="product-info-meta product-info-meta-{{ section.id }} {{ product_info_meta_stretch_class }} {% if is_variant_selected == false %}visually-hidden{% endif %}"
                          >
                            {% unless settings.catalog_enabled %}
                              {% if block.settings.show_stock %}
                                {% if product != blank %}
                                  <div
                                    id="ProductAvailability-{{ section.id }}"
                                    class="product-info-meta-item"
                                  >
                                    {% render 'product-availability', product: product %}
                                  </div>
                                {% else %}
                                  <div
                                    id="ProductAvailability-{{ section.id }}"
                                    class="product-info-meta-item"
                                  >
                                    <div class="badge-stock badge-stock-out">
                                      <span class="badge-stock-dot"></span>
                                      <span class="js-stock-text">
                                        {{- 'products.product.availability.out_of_stock' | t -}}
                                      </span>
                                    </div>
                                  </div>
                                {% endif %}
                              {% endif %}
                            {% endunless %}

                            {% if block.settings.show_sku
                              and product.selected_or_first_available_variant.sku != blank
                            %}
                              <span class="product-info-meta-item product-info-meta-item-code">
                                {{ 'products.product.sku' | t }}:
                                <span
                                  id="ProductSku-{{ section.id }}"
                                  class="ProductSku-{{ section.id }}"
                                >
                                  {{- product.selected_or_first_available_variant.sku -}}
                                </span>
                              </span>
                            {% endif %}

                            {% if block.settings.show_barcode %}
                              {% if product.selected_or_first_available_variant.barcode != blank %}
                                <span class="product-info-meta-item product-info-meta-item-code">
                                  {% if block.settings.barcode_label != blank %}
                                    {{ block.settings.barcode_label }}:
                                  {% endif %}
                                  <span
                                    id="ProductBarcode-{{ section.id }}"
                                    class="ProductBarcode-{{ section.id }}"
                                  >
                                    {{- product.selected_or_first_available_variant.barcode -}}
                                  </span>
                                </span>
                              {% endif %}
                            {% endif %}

                            {% if block.settings.show_rating %}
                              <div class="product-info-meta-item last {% if block.settings.hide_empty_star_rating %}product-rating-hide-empty{% endif %}">
                                {% render 'product-rating-widget', product: product %}
                              </div>
                            {% endif %}
                          </div>
                        {% endif %}
                      </div>
                    {% when 'extra' %}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        <div class="product-info-extra">
                          {% if block.settings.text != blank %}
                            <div class="product-info-extra-aux rte">
                              {{ block.settings.text }}
                            </div>
                          {% endif %}

                          {% if block.settings.show_facebook
                            or block.settings.show_twitter
                            or block.settings.show_linkedin
                          %}
                            <div class="product-info-extra-sharing">
                              <ul class="list-social">
                                {% if block.settings.show_facebook %}
                                  <li class="list-social-item">
                                    <a
                                      href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ product.url | url_encode }}"
                                      data-share-url="https://www.facebook.com/sharer.php?u="
                                      target="_blank"
                                      class="list-social-link"
                                    >
                                      <span class="visually-hidden">
                                        {{- 'general.social.share_on_facebook' | t -}}
                                      </span>
                                      {% render 'icons', icon: 'facebook' %}
                                    </a>
                                  </li>
                                {% endif %}
                                {% if block.settings.show_twitter %}
                                  <li class="list-social-item">
                                    <a
                                      href="https://x.com/share?url={{ shop.url }}{{ product.url | url_encode }}"
                                      data-share-url="https://x.com/share?url="
                                      target="_blank"
                                      class="list-social-link"
                                    >
                                      <span class="visually-hidden">
                                        {{- 'general.social.share_on_x' | t -}}
                                      </span>
                                      {% render 'icons', icon: 'x' %}
                                    </a>
                                  </li>
                                {% endif %}
                                {% if block.settings.show_linkedin %}
                                  <li class="list-social-item">
                                    <a
                                      href="https://www.linkedin.com/sharing/share-offsite/?url={{ shop.url }}{{ product.url | url_encode }}"
                                      data-share-url="https://www.linkedin.com/sharing/share-offsite/?url="
                                      target="_blank"
                                      class="list-social-link"
                                    >
                                      <span class="visually-hidden">
                                        {{- 'general.social.share_on_linkedin' | t -}}
                                      </span>
                                      {% render 'icons', icon: 'linkedin' %}
                                    </a>
                                  </li>
                                {% endif %}
                              </ul>
                            </div>
                          {% endif %}
                        </div>
                      </div>

                    {%- when 'price' -%}
                      {% unless settings.catalog_enabled %}
                        <div
                          class="product-block product-block-price {% if block.settings.show_bottom_divider %}has-divider{% endif %} product-block-content-{{ section.id }} variant-changed-update"
                          {{ block.shopify_attributes }}
                        >
                          {%- capture login_for_price -%}{%- render 'price-get-login-for-price', product: product -%}{%- endcapture -%}
                          {%- assign login_for_price = login_for_price | strip -%}
                          {% if login_for_price == 'true' %}
                            <div
                              class="{% if is_variant_selected == false %}visually-hidden{% endif %}"
                              id="price-{{ section.id }}"
                              role="status"
                            >
                              {% render 'price-login-for-price' %}
                            </div>
                          {% else %}
                            <div
                              class="{% if is_variant_selected == false %}visually-hidden{% endif %}"
                              id="price-{{ section.id }}"
                              role="status"
                            >
                              {% render 'price',
                                product: product,
                                discount_badge: true,
                                use_variant: true
                              %}

                              {% if product != blank %}
                                {%- form 'product',
                                  product,
                                  id: 'product-form-installment',
                                  class: 'installment',
                                  data-event-context: 'FeaturedProductSectionInstallment'
                                -%}
                                  <input
                                    type="hidden"
                                    name="id"
                                    value="{{ product.selected_or_first_available_variant.id }}"
                                  >
                                  {{ form | payment_terms }}
                                {%- endform -%}
                              {% endif %}
                            </div>
                          {% endif %}
                        </div>
                      {% endunless %}

                    {%- when 'variants' -%}
                      {% render 'product-variant-picker',
                        section: section,
                        block: block,
                        product: product,
                        product_form_id: product_form_id,
                        equal_width: block.settings.picker_equal_width,
                        update_url: false,
                        size: block.settings.picker_size,
                        shape: block.settings.picker_shape,
                        preselect_variant: section.settings.preselect_variant
                      %}

                    {% when 'buy_buttons' %}
                      {% unless settings.catalog_enabled %}
                        {%- capture login_for_price -%}{%- render 'price-get-login-for-price', product: product -%}{%- endcapture -%}
                        {%- assign login_for_price = login_for_price | strip -%}
                        {%- capture show_call_for_pricing -%}{%- render 'price-get-call-for-pricing', product: product, use_variant: true -%}{%- endcapture -%}
                        {%- assign show_call_for_pricing = show_call_for_pricing | strip -%}

                        {% if login_for_price != 'true' %}
                          {%- liquid
                            assign gift_card_recipient_feature_active = false
                            if block.settings.show_gift_card_recipient and product.gift_card?
                              assign gift_card_recipient_feature_active = true
                            endif

                            assign show_dynamic_checkout = false
                            if block.settings.show_buy_now and gift_card_recipient_feature_active == false and is_pre_order == false
                              assign show_dynamic_checkout = true
                            endif
                          -%}

                          <div
                            class="product-block product-block-{{ block.id }} {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                            {{ block.shopify_attributes }}
                          >
                            {% if product != blank %}
                              <product-form
                                class="product-form {% unless is_variant_selected %}visually-hidden{% endunless %}"
                                data-hide-errors="{{ gift_card_recipient_feature_active }}"
                              >
                                <div
                                  class="product-form-error-message-wrapper form-status form-status-error"
                                  role="alert"
                                  hidden
                                >
                                  <span class="product-form-error-message"></span>
                                </div>

                                {% form 'product',
                                  product,
                                  id: product_form_id,
                                  class: 'form',
                                  novalidate: 'novalidate',
                                  data-type: 'add-to-cart-form',
                                  data-stock-threshold: settings.only_x_left,
                                  data-event-context: 'FeaturedProductSection'
                                %}
                                  <input
                                    type="hidden"
                                    name="id"
                                    value="{{ product.selected_or_first_available_variant.id }}"
                                    {% if product.selected_or_first_available_variant.available
                                        == false
                                      or product.selected_or_first_available_variant == null
                                    %}
                                      disabled
                                    {% endif %}
                                  >

                                  {%- if gift_card_recipient_feature_active -%}
                                    {%- render 'gift-card-recipient-form',
                                      product: product,
                                      form: form,
                                      section: section
                                    -%}
                                  {%- endif -%}

                                  <div class="product-actions color-button-{{ block.settings.button_color_scheme }}">
                                    {% if show_call_for_pricing == 'true' %}
                                      {% render 'price-call-for-pricing',
                                        product: product,
                                        use_variant: true
                                      %}
                                    {% else %}
                                      <div class="product-actions-add-to-cart">
                                        {% if block.settings.show_quantity %}
                                          <quantity-input class="quantity-input">
                                            <button
                                              type="button"
                                              name="minus"
                                              class="quantity-input-button quantity-input-minus"
                                            >
                                              &minus;
                                              <span class="visually-hidden">
                                                {{-
                                                  'products.product.quantity.decrease'
                                                  | t: product: product.title
                                                  | escape
                                                -}}
                                              </span>
                                            </button>
                                            <label
                                              for="quantity-input-{{ section.id }}"
                                              class="visually-hidden"
                                            >
                                              {{- 'products.product.quantity.label' | t -}}
                                            </label>
                                            <input
                                              name="quantity"
                                              type="number"
                                              class="quantity-input-field"
                                              id="quantity-input-{{ section.id }}"
                                              min="1"
                                              value="1"
                                              form="{{ product_form_id }}"
                                            >
                                            <button
                                              type="button"
                                              name="plus"
                                              class="quantity-input-button quantity-input-plus"
                                            >
                                              &plus;
                                              <span class="visually-hidden">
                                                {{-
                                                  'products.product.quantity.increase'
                                                  | t: product: product.title
                                                  | escape
                                                -}}
                                              </span>
                                            </button>
                                          </quantity-input>
                                        {% endif %}

                                        {% if block.settings.show_add_to_cart %}
                                          <button
                                            type="submit"
                                            name="add"
                                            class="button button-add-to-cart {% if show_dynamic_checkout %} button-secondary{% endif %}"
                                            {% if product.selected_or_first_available_variant.available
                                                == false
                                              or product.selected_or_first_available_variant == null
                                            %}
                                              disabled
                                            {% endif %}
                                          >
                                            {%- if product.selected_or_first_available_variant
                                                == null
                                            -%}
                                              <span>
                                                {{-
                                                  'products.product.availability.unavailable'
                                                  | t
                                                -}}
                                              </span>
                                            {%- elsif product.selected_or_first_available_variant.available
                                              and is_pre_order
                                            -%}
                                              <span>{{ 'products.product.pre_order' | t }}</span>
                                            {%- elsif product.selected_or_first_available_variant.inventory_policy
                                                == 'continue'
                                              and product.selected_or_first_available_variant.inventory_quantity
                                                <= 0
                                            -%}
                                              <span>{{ 'products.product.backorder' | t }}</span>
                                            {%- elsif product.selected_or_first_available_variant.available -%}
                                              <span>
                                                {{- 'products.product.add_to_cart' | t -}}
                                              </span>
                                            {%- else -%}
                                              <span>
                                                {{-
                                                  'products.product.availability.out_of_stock'
                                                  | t
                                                -}}
                                              </span>
                                            {%- endif -%}

                                            <div class="button-overlay-spinner hidden">
                                              <span class="spinner-xs"></span>
                                            </div>
                                          </button>
                                        {% endif %}
                                      </div>

                                      {% if show_dynamic_checkout %}
                                        <div class="product-actions-buy-now">
                                          {{ form | payment_button }}
                                        </div>
                                      {% endif %}
                                    {% endif %}
                                  </div>
                                {% endform %}
                              </product-form>
                            {% else %}
                              <div class="product-form" {{ block.shopify_attributes }}>
                                <div class="product-actions">
                                  <div class="product-actions-add-to-cart">
                                    {% if block.settings.show_quantity %}
                                      <quantity-input class="quantity-input">
                                        <button
                                          type="button"
                                          name="minus"
                                          class="quantity-input-button quantity-input-minus"
                                        >
                                          &minus;
                                          <span class="visually-hidden">
                                            {{-
                                              'products.product.quantity.decrease'
                                              | t: product: product.title
                                              | escape
                                            -}}
                                          </span>
                                        </button>
                                        <label for="quantity-input" class="visually-hidden">
                                          {{- 'products.product.quantity.label' | t -}}
                                        </label>
                                        <input
                                          name="quantity"
                                          type="number"
                                          class="quantity-input-field"
                                          id="quantity-input"
                                          min="1"
                                          value="1"
                                          form="{{ product_form_id }}"
                                        >
                                        <button
                                          type="button"
                                          name="plus"
                                          class="quantity-input-button quantity-input-plus"
                                        >
                                          &plus;
                                          <span class="visually-hidden">
                                            {{-
                                              'products.product.quantity.increase'
                                              | t: product: product.title
                                              | escape
                                            -}}
                                          </span>
                                        </button>
                                      </quantity-input>
                                    {% endif %}

                                    {% if block.settings.show_add_to_cart %}
                                      <button
                                        type="submit"
                                        name="add"
                                        class="button button-secondary button-add-to-cart"
                                        disabled=""
                                      >
                                        <span>
                                          {{- 'products.product.availability.out_of_stock' | t -}}
                                        </span>
                                        <span class="button-overlay-spinner hidden">
                                          <span class="spinner-xs"></span>
                                        </span>
                                      </button>
                                    {% endif %}
                                  </div>
                                </div>
                              </div>
                            {% endif %}
                          </div>
                        {% endif %}
                      {% endunless %}

                    {% when 'request_information' %}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-request-information',
                          product: product,
                          settings: block.settings,
                          block: block
                        %}
                      </div>

                    {% when 'contact_details' %}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-contact-details',
                          settings: block.settings,
                          block: block
                        %}
                      </div>

                    {% when 'product_signup' %}
                      {% liquid
                        assign show_product_signup = true
                        if block.settings.show_when == 'out_of_stock'
                          assign show_product_signup = false
                          if selected_variant.available == false
                            assign show_product_signup = true
                          endif
                        endif
                      %}
                      <div
                        id="ProductSignup-{{ section.id }}"
                        class="
                          product-block
                          {% if block.settings.show_bottom_divider %}has-divider{% endif %}
                          {% if show_product_signup == false %}hidden{% endif %}
                          product-block-content-{{ section.id }} variant-changed-update
                        "
                        {{ block.shopify_attributes }}
                      >
                        {% assign form_id = 'form-'
                          | append: section.id
                          | append: '-block-'
                          | append: forloop.index
                        %}
                        {% render 'main-product-signup',
                          id: form_id,
                          product: product,
                          block: block
                        %}
                      </div>

                    {% when 'stock_bar' %}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %} product-block-content-{{ section.id }} variant-changed-update"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-stock-bar',
                          product: product,
                          section: section,
                          block: block,
                          variant: selected_variant
                        %}
                      </div>

                    {% when 'info_box' %}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-info-box', settings: block.settings, block: block %}
                      </div>

                    {% when 'image' %}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-image-block',
                          settings: block.settings,
                          block: block
                        %}
                      </div>

                    {% when 'product_metadata' %}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-metadata-block',
                          product: product,
                          settings: block.settings,
                          block: block
                        %}
                      </div>

                    {%- when 'details' -%}
                      <div class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}">
                        {% render 'main-product-details',
                          product: product,
                          block: block,
                          position: 'right'
                        %}
                      </div>

                    {%- when 'range_indicator' -%}
                      {% if block.settings.value != blank or request.design_mode %}
                        <div
                          class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                          {{ block.shopify_attributes }}
                        >
                          {% render 'main-product-range-indicator',
                            title: block.settings.label,
                            from: block.settings.range_from,
                            to: block.settings.range_to,
                            value: block.settings.value,
                            track_color: block.settings.track_color,
                            filled_color: block.settings.filled_color,
                            block: block
                          %}
                        </div>
                      {% endif %}

                    {%- when 'custom_liquid' -%}
                      {% capture liquid_output %}{{ block.settings.custom_liquid }}{% endcapture %}
                      {% if liquid_output != blank %}
                        <div
                          class="product-info-details custom-liquid"
                          {{ block.shopify_attributes }}
                        >
                          <div class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}">
                            {% if block.settings.title != blank or block.settings.icon != blank %}
                              <div class="product-info-details-title h5">
                                {% if block.settings.icon == 'custom'
                                  and block.settings.custom_icon != blank
                                %}
                                  <img
                                    src="{{ block.settings.custom_icon | image_url: width: 48 }}"
                                    alt="{{ block.settings.title }}"
                                    width="24"
                                    height="24"
                                  >
                                {% elsif block.settings.icon != blank %}
                                  {% render 'icons', icon: block.settings.icon %}
                                {% endif %}
                                {{ block.settings.title }}
                              </div>
                            {% endif %}

                            {{ block.settings.custom_liquid }}
                          </div>
                        </div>
                      {% endif %}

                    {%- when 'personalization_text' -%}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        <div
                          class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                          {{ block.shopify_attributes }}
                        >
                          {% render 'main-product-personalization-fields',
                            product: product,
                            settings: block.settings,
                            block: block,
                            product_form_id: product_form_id
                          %}
                        </div>
                      </div>
                    {%- when 'countdown' -%}
                      {% render 'main-product-countdown',
                        section: section,
                        block: block,
                        variant: selected_variant
                      %}

                    {% when 'highlights' %}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-highlights', block: block %}
                      </div>

                    {%- when 'payment_icons' -%}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-payment-icons' %}
                      </div>

                    {% when 'content_drawer' %}
                      {% if block.settings.richtext_content != blank
                        or block.settings.page_content != blank
                        or block.settings.link_text != blank
                      %}
                        {% assign has_content_drawer = true %}
                        {% render 'main-product-content-drawer', block: block %}
                      {% endif %}

                    {%- when 'table' -%}
                      <div class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}">
                        {% render 'main-product-table', block: block, position: 'right' %}
                      </div>

                    {%- when 'coupon_code' -%}
                      <div
                        class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {% render 'main-product-coupon', block: block %}
                      </div>

                    {%- when 'custom_badges' -%}
                      <div
                        class="product-block product-block-custom-badges{% if block.settings.show_bottom_divider %} has-divider{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        {%- render 'card-product-custom-badges',
                          product: product,
                          class: 'product-info-badges product-info-badges-block'
                        -%}
                      </div>

                    {%- when 'product_collections' -%}
                      {% if product.collections.size > 0 %}
                        <div
                          class="product-block {% if block.settings.show_bottom_divider %}has-divider{% endif %}"
                          {{ block.shopify_attributes }}
                        >
                          {% if block.settings.title != blank %}
                            <div class="product-info-details-title h5">
                              {% if block.settings.icon == 'custom'
                                and block.settings.custom_icon != blank
                              %}
                                <img
                                  src="{{ block.settings.custom_icon | image_url: width: 48 }}"
                                  alt="{{ block.settings.title }}"
                                  width="24"
                                  height="24"
                                >
                              {% elsif block.settings.icon != blank %}
                                {% render 'icons', icon: block.settings.icon %}
                              {% endif %}
                              {{ block.settings.title }}
                            </div>
                          {% endif %}
                          <div class="product-collections-list">
                            {% for collection in product.collections
                              limit: block.settings.max_collections
                            %}
                              <a href="{{ collection.url }}" class="product-collections-link">
                                {{- collection.title -}}
                              </a>
                              {%- unless forloop.last -%}
                                <span class="product-collections-separator">
                                  {{- block.settings.separator -}}
                                </span>
                              {%- endunless -%}
                            {% endfor %}
                          </div>
                        </div>
                      {% endif %}
                  {% endcase %}
                {% endfor %}

                <div class="product-info-secondary">
                  <a
                    {% if product == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ product.url }}"
                    {% endif %}
                    class="button-text-link"
                  >
                    {{ 'products.product.view_full_details' | t }}
                    {% render 'angle', direction: 'right' %}
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- if first_3d_model -%}
    <script type="application/json" id="ProductJSON-{{ product.id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
    </script>

    <script src="{{ 'product-model.js' | asset_url }}" defer></script>
  {%- endif -%}

  {% if has_media %}
    <script src="{{ 'flickity.pkgd.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
    {% if section.settings.arrow_navigation %}
      <script src="{{ 'carousel-slider.js' | asset_url }}" defer="defer"></script>
    {% endif %}
  {% endif %}

  {% if has_content_drawer %}
    <script src="{{ 'content-drawer.js' | asset_url }}" defer="defer"></script>
  {% endif %}

  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>
{%- endunless -%}
